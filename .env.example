# Rocket Factory 환경 변수 설정
# 이 파일을 .env로 복사하고 값을 수정하세요

# ==================
# Backend 설정
# ==================
NODE_ENV=production
PORT=3001
FRONTEND_URL=http://localhost:3000

# ==================
# 데이터베이스 설정
# ==================
DATABASE_HOST=mariadb
DATABASE_USER=rocketuser
DATABASE_PASSWORD=rocketpassword
DATABASE_NAME=rocket_factory
DATABASE_PORT=3306

# ==================
# Frontend 설정
# ==================
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_SOCKET_URL=http://localhost

# ==================
# MariaDB 설정
# ==================
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=rocket_factory
MYSQL_USER=rocketuser
MYSQL_PASSWORD=rocketpassword

# ==================
# 프로덕션 설정 (배포 시 수정)
# ==================
# NEXT_PUBLIC_API_URL=https://yourdomain.com/api
# NEXT_PUBLIC_SOCKET_URL=https://yourdomain.com
# DATABASE_HOST=production-db-server
# MYSQL_ROOT_PASSWORD=strong-random-password-here
# MYSQL_PASSWORD=strong-random-password-here
